# PATH 管理レイヤの activation。順序依存あり(mise が先)。詳細は docs/tools/adding-tools.md

# mise
eval "$(mise activate zsh)"
# mise で入れたツールのシェルフック(opam 等)
[ -r "${XDG_CONFIG_HOME:-$HOME/.config}/mise/shell-hooks.zsh" ] && . "${XDG_CONFIG_HOME:-$HOME/.config}/mise/shell-hooks.zsh"
# cargo
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"
# starship
eval "$(starship init zsh)"
