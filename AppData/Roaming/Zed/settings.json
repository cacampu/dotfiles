// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "cli_default_open_behavior": "new_window",
    "project_panel": {
        "dock": "left"
    },
    "outline_panel": {
        "dock": "left"
    },
    "collaboration_panel": {
        "dock": "left"
    },
    "git_panel": {
        "dock": "left"
    },
    "wsl_connections": [
        {
            "distro_name": "docker-desktop",
            "user": null,
            "projects": []
        }
    ],
    "languages": {
        "Markdown": {
            "soft_wrap": "prefer_line"
        },
        "C++": {
            "format_on_save": "on"
        },
        "Nim": {
            "format_on_save": "on",
            "formatter": "language_server"
        }
    },
    "soft_wrap": "prefer_line",
    "edit_predictions": {
        "mode": "eager"
    },
    "disable_ai": true,
    "agent": {
        "dock": "right",
        "default_profile": "write",
        "default_model": {
            "enable_thinking": true,
            "provider": "google",
            "model": "gemini-3.1-pro-preview"
        },
        "model_parameters": []
    },
    "autosave": "on_focus_change",
    "telemetry": {
        "diagnostics": true,
        "metrics": true
    },
    "base_keymap": "VSCode",
    "relative_line_numbers": "enabled",
    "gutter": {
        "line_numbers": true
    },
    "minimap": {
        "show": "auto"
    },
    "file_types": {
        "TOML": ["Cargo.toml"]
    },
    "language": {},
    "vim_mode": true,
    "icon_theme": {
        "mode": "system",
        "light": "Zed (Default)",
        "dark": "Zed (Default)"
    },
    "buffer_font_family": "JetBrains Mono",
    "buffer_font_fallbacks": ["BIZ UDGothic"],
    "buffer_font_features": { "calt": true },
    "ui_font_size": 16,
    "buffer_font_size": 13.5,
    "theme": "Gruvbox Dark",
    "show_ligatures": true
}
